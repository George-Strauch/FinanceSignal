{
  "jobs": [
    {
      "id": "reddit_scraper",
      "name": "Reddit Scraper",
      "description": "Fetches posts and comments from configured subreddits, extracts ticker mentions",
      "module": "app.scraper",
      "function": "run_collector",
      "type": "continuous",
      "auto_start": false,
      "params": [
        {
          "key": "cycle_interval_hours",
          "label": "Cycle Interval",
          "type": "number",
          "default": 3,
          "unit": "hours",
          "min": 0.5,
          "max": 24,
          "step": 0.5,
          "description": "Time between scraping cycles"
        },
        {
          "key": "request_delay_seconds",
          "label": "Request Delay",
          "type": "number",
          "default": 6.0,
          "unit": "seconds",
          "min": 2,
          "max": 30,
          "step": 0.5,
          "description": "Minimum delay between Reddit API requests"
        }
      ]
    },
    {
      "id": "ticker_reprocess",
      "name": "Ticker Reprocess",
      "description": "Re-extract tickers from all posts and comments (one-time cleanup)",
      "module": "app.scraper",
      "function": "reprocess_all_tickers",
      "type": "oneshot",
      "auto_start": false
    }
  ]
}
